class CuentaBancaria {
  double _saldo = 0;   

   
  double get saldo => _saldo;

  
  set saldo(double monto) {
    if (monto >= 0) {
      _saldo = monto;
    }
  }
}

void main() {
  
  CuentaBancaria cuenta = CuentaBancaria();

  
  cuenta.saldo = 1500.75;
  print("Saldo válido: ${cuenta.saldo}");

  
  cuenta.saldo = -500;
  print("Saldo tras intento inválido: ${cuenta.saldo}");
}
